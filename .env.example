# ============================================
# LangChain TypeScript AI Assistant - ENV CONFIG
# ============================================

# --- REQUIRED: Choose ONE model provider ---

# Option A: OpenAI (recommended for LangChain tutorials)
OPENAI_API_KEY=sk-your-openai-key-here

# Option B: Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# --- REQUIRED: LangSmith for tracing & debugging ---
# Sign up free at: https://smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__your-langsmith-key-here
LANGCHAIN_PROJECT=langchain-ts-assistant

# --- OPTIONAL: Tavily for web search in agent ---
# Sign up free at: https://tavily.com
TAVILY_API_KEY=tvly-your-tavily-key-here

# --- Model selection (openai or anthropic) ---
MODEL_PROVIDER=openai
