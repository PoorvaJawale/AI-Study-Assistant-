{
  "name": "langchain-ts-assistant",
  "version": "1.0.0",
  "description": "TypeScript LangChain AI Assistant with Chains, Memory, Agents, and LangSmith Debugging",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node --transpile-only src/index.ts",
    "chains": "ts-node --transpile-only src/chains.ts",
    "memory": "ts-node --transpile-only src/memory.ts",
    "agent": "ts-node --transpile-only src/agent.ts",
    "demo": "ts-node --transpile-only src/demo.ts"
  },
  "dependencies": {
    "@langchain/anthropic": "^0.3.0",
    "@langchain/community": "^0.3.0",
    "@langchain/core": "^0.3.0",
    "@langchain/langgraph": "^0.2.0",
    "@langchain/openai": "^0.3.0",
    "dotenv": "^16.4.5",
    "langchain": "^0.3.0",
    "langsmith": "^0.2.0",
    "readline": "^1.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  },
  "keywords": ["langchain", "typescript", "ai", "openai", "langsmith", "agents"],
  "author": "Poorva Jawale",
  "license": "MIT"
}
